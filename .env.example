# Port for Express health/status server
PORT=3000

# Hugging Face Access Token with WRITE permissions
HF_TOKEN=your_huggingface_write_token_here

# Hugging Face Dataset Repository (Format: username/dataset-name)
HF_DATASET=your_username/your_dataset_name

# Admin WhatsApp Phone Number (Format: international_number@c.us, e.g., 966500000000@c.us)
ADMIN_NUMBER=966500000000@c.us

# Maximum allowed file size for PDF uploads in Megabytes (Default: 50)
MAX_FILE_SIZE_MB=50

# Rate limiting: minimum interval between user messages in milliseconds (Default: 1000ms = 1s)
RATE_LIMIT_MS=1000

# Cooldown between new book requests from the same user in milliseconds (Default: 180000ms = 3 minutes)
REQUEST_COOLDOWN_MS=180000
